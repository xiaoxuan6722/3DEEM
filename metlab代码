            batch_num = b;
            break;
        end
    end %判断当前样品属于哪个批次
     
    Sub_Matrix = S_Matrix - blank_matrices{batch_num};
    Sub_Matrix(Sub_Matrix < 0) = 0;
    X_Sub(i, :, :) = Sub_Matrix / q_batches(batch_num);
end

