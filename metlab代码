%% 2. 读取文件并按原始文件系统顺序排序
sampleFiles = dir(fullfile(sampleFolder, '*.xlsx'));
blankFiles = dir(fullfile(blankFolder, '*.xlsx'));

% 样品按字母顺序排序（保持原始顺序）
[~, sample_order] = sort({sampleFiles.name});
sampleFiles = sampleFiles(sample_order);

% 空白按数字排序
[~, blank_order] = sort(str2double(regexp({blankFiles.name}, '\d+', 'match', 'once')));
blankFiles = blankFiles(blank_order);

nSample = length(sampleFiles);

firstFile = readmatrix(fullfile(sampleFolder, sampleFiles(1).name));
Ex = firstFile(1, 2:end);
Em = firstFile(2:end, 1);
nEx = length(Ex);
nEm = length(Em);

%% 3. 分批次拉曼归一化
Em_raman_range = [371, 428]; %定义拉曼峰的发射波长范围：371-428 nm
Ex_raman = 350; %定义拉曼峰的激发波长：350 nm
[~, idx_em_start] = min(abs(Em - Em_raman_range(1))); %找到发射波长数组 Em 中最接近 371nm 的索引位置
[~, idx_em_end] = min(abs(Em - Em_raman_range(2))); %找到发射波长数组中最接近 428nm 的索引位置
[~, idx_ex_raman] = min(abs(Ex - Ex_raman)); %找到激发波长数组 Ex 中最接近 350nm 的索引位置


batches = {1:60, 61:84, 85:106, 107:127}; %这里是修改的，我这里的意思是1-60是一个批次的共用一个空白
%定义 4 个批次的样品编号范围
blank_indices = [1, 61, 85, 107];
%定义每个批次使用的空白编号

q_batches = zeros(4, 1);%创建一个 4×1 的数组，用于存储 4 个批次的拉曼峰面积
blank_matrices = cell(4, 1);%创建一个 cell 数组，用于存储 4 个空白的 EEM 矩阵
%每个空白的 EEM 矩阵大小为 nEm × nEx

for b = 1:4 %1：4需要修改
    blank_idx = blank_indices(b);
    bData = readmatrix(fullfile(blankFolder, blankFiles(blank_idx).name));
    blank_matrices{b} = bData(2:end, 2:end);
    blank_ex350 = blank_matrices{b}(:, idx_ex_raman);
    q_batches(b) = trapz(Em(idx_em_start:idx_em_end), blank_ex350(idx_em_start:idx_em_end));
    %计算拉曼峰的积分面积
end

fprintf('各批次拉曼峰面积:\n');
