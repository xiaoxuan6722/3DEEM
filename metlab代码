fprintf('  批次 2 (61-84):   %.2f (空白 #%d)\n', q_batches(2), blank_indices(2));
fprintf('  批次 3 (85-106):  %.2f (空白 #%d)\n', q_batches(3), blank_indices(3));
fprintf('  批次 4 (107-127): %.2f (空白 #%d)\n', q_batches(4), blank_indices(4));
fprintf('批次间拉曼峰差异: %.2f%%\n', std(q_batches)/mean(q_batches)*100);

X_Sub = zeros(nSample, nEm, nEx); %创建一个 3D 数组，用于存储归一化后的所有样品 EEM
SampleNames = cell(nSample, 1);

for i = 1:nSample
    sFileName = sampleFiles(i).name;
    [~, SampleNames{i}, ~] = fileparts(sFileName);
    sData = readmatrix(fullfile(sampleFolder, sFileName));
    S_Matrix = sData(2:end, 2:end);
    
    for b = 1:4 %1：4修改修改
